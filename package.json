{
  "name": "ms-ch5",
  "version": "1.0.0",
  "description": "Crestron HTML5 Home Control Panel",
  "main": "index.js",
  "scripts": {
    "clean": "rimraf dist/",
    "start": "npm run clean && webpack --config webpack.dev.js",
    "build:prod": "npm run clean && webpack --config webpack.prod.js",
    "build:archive": "ch5-cli archive -p ms-ch5 -d dist/ms-ch5 -o dist",
    "build:deploy": "ch5-cli deploy -H 192.168.1.x -t touchscreen dist/ms-ch5.ch5z",
    "build:onestep": "npm run build:prod && npm run build:archive && npm run build:deploy"
  },
  "devDependencies": {
    "browser-sync": "^2.26.7",
    "browser-sync-webpack-plugin": "^2.2.2",
    "copy-webpack-plugin": "^5.0.3",
    "css-loader": "^3.0.0",
    "file-loader": "^4.0.0",
    "glob": "^7.1.4",
    "html-loader": "^0.5.5",
    "html-webpack-plugin": "^3.2.0",
    "mini-css-extract-plugin": "^0.7.0",
    "rimraf": "^2.6.3",
    "url-loader": "^2.0.0",
    "webpack": "^4.46.0",
    "webpack-cli": "^3.3.19",
    "webpack-concat-plugin": "^3.0.0",
    "webpack-merge": "^4.2.1"
  },
  "dependencies": {
    "@crestron/ch5-crcomlib": "^2.8.0",
    "@fortawesome/fontawesome-free": "^5.15.4"
  }
}
