{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dev",
      "runtimeExecutable": "/usr/local/bin/node",
      "runtimeArgs": ["./node_modules/.bin/webpack", "--config", "webpack.dev.js"],
      "port": 3000,
      "autoPort": false,
      "env": {
        "PATH": "/usr/local/bin:/usr/bin:/bin"
      }
    },
    {
      "name": "mockups",
      "runtimeExecutable": "/usr/local/bin/npx",
      "runtimeArgs": ["http-server", "./mockups", "-p", "8090", "-c-1"],
      "port": 8090,
      "env": {
        "PATH": "/usr/local/bin:/usr/bin:/bin"
      }
    }
  ]
}
